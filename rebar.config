%% ex: ts=4 sw=4 noexpandtab syntax=erlang

{erl_opts, [debug_info, fail_on_warning]}.
{edoc_opts, [{index_columns, 1}, {sort_functions, false}, {preprocess, true}]}.
{dialyzer, [
  {warnings, [error_handling, unmatched_returns]},
  {get_warnings, true},
  {plt_apps, top_level_deps},
  {plt_extra_apps, [ssl]},
  {plt_location, "_build/dialyzer/project"},
  {base_plt_location, "_build/dialyzer/base"},
  {base_plt_prefix, "rebar3_base"}
]}.

{deps, [
  {bson, ".*",
   {git, "https://github.com/comtihon/bson-erlang.git", {tag, "v0.2.4"}}},
  {pbkdf2, ".*",
   {git, "https://github.com/comtihon/erlang-pbkdf2.git", {tag, "2.0.1"}}},
  {poolboy, ".*",
   {git, "https://github.com/comtihon/poolboy.git", {branch, "1.6.1"}}}
]}.

{profiles, [
  {test, [
    {deps, [
      {proper, "1.4.0"}
    ]}
  ]}
]}.

{clean_files, [
  "erl_crash.dump",
  "doc/*.html",
  "doc/erlang.png",
  "doc/edoc-info",
  "doc/stylesheet.css"
]}.
{alias, [
  {ci_test, [eunit, ct]},
  {ci_coverage, [
    {eunit, "--cover --cover_export_name eunit.coverdata"},
    {ct, "--cover --cover_export_name ct.coverdata"},
    {cover, "--verbose"}
  ]},
  {ci_dialyzer, [dialyzer]}
]}.
